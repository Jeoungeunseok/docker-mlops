# MLOps infrastructure settings.
# Use with:
# docker compose --env-file .env.mlops -f docker-compose.yml -f docker-compose.mlops.yml up -d

TZ=Asia/Seoul

API_PORT=8000
APP_NAME=MLOps API
APP_VERSION=0.1.0
APP_ENV=local
APP_TIMEZONE=Asia/Seoul
ENABLE_DOCS=true
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_FILE_PATH=logs/app.log
LOG_RETENTION_DAYS=30
PREDICTION_LOG_STORE=in_memory
TRAINING_JOB_STORE=in_memory

APP_DB_PORT=5434
APP_DB_NAME=app
APP_DB_USER=app
APP_DB_PASSWORD=change_me_app_db_password

MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=default-model-serving
MODEL_CHAMPION_ALIAS=champion
MODEL_CANDIDATE_ALIAS=candidate
MLOPS_MIN_VALIDATION_SAMPLES=100
MLOPS_MAX_MAPE_FOR_PROMOTION=15.0
MLOPS_METRIC_FOR_PROMOTION=rmse
MLOPS_ENABLE_SCHEDULED_RETRAINING=false
MLOPS_SCHEDULED_RETRAINING_JOBS=[]

MLFLOW_DB_PORT=5433
MLFLOW_DB_NAME=mlflow
MLFLOW_DB_USER=mlflow
MLFLOW_DB_PASSWORD=change_me_mlflow_db_password
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=change_me_minio_user
MINIO_ROOT_PASSWORD=change_me_minio_password
