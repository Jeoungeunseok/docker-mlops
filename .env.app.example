APP_NAME=MLOps API
APP_VERSION=0.1.0
APP_ENV=local
APP_TIMEZONE=Asia/Seoul
ENABLE_DOCS=true
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_FILE_PATH=logs/app.log
LOG_RETENTION_DAYS=30
APP_DATABASE_URL=postgresql://app:app_pass@localhost:5434/app
PREDICTION_LOG_STORE=in_memory
TRAINING_JOB_STORE=in_memory
MLOPS_EVENT_STORE=in_memory

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=default-model-serving
MODEL_CHAMPION_ALIAS=champion
MODEL_CANDIDATE_ALIAS=candidate

MLOPS_MIN_VALIDATION_SAMPLES=100
MLOPS_MAX_MAPE_FOR_PROMOTION=15.0
MLOPS_METRIC_FOR_PROMOTION=rmse
MLOPS_ENABLE_SCHEDULED_RETRAINING=false
MLOPS_SCHEDULED_RETRAINING_JOBS=[]
MLOPS_DRIFT_MIN_SAMPLES=30
MLOPS_DRIFT_METRIC_NAME=mape
# MLOPS_DRIFT_MAX_MEAN_ERROR_VALUE=10.0
# MLOPS_DRIFT_MAX_MEAN_METRIC_VALUE=15.0
MLOPS_NOTIFICATION_SINK=disabled
# MLOPS_NOTIFICATION_WEBHOOK_URL=https://example.com/mlops-webhook
